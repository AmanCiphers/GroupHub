# GroupHub backend environment variables
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

NODE_ENV=development
PORT=5050
API_BASE_URL=http://localhost:5050
CLIENT_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:5050

# Generate a random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET=change_me_to_a_random_string_at_least_16_chars

# MongoDB: use your own connection string
MONGODB_URI=mongodb://localhost:27017/grouphub
MONGODB_DB_NAME=grouphub

# JWT secrets: generate unique random strings
JWT_ACCESS_SECRET=change_me_to_a_random_string_at_least_16_chars
JWT_REFRESH_SECRET=change_me_to_a_different_random_string_at_least_16_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# Email (Resend) — optional for development
RESEND_API_SECRET=
EMAIL_FROM=

# AI (Groq) — optional for development
AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Redis — optional for development
REDIS_URL=
REDIS_TOKEN=

# Sentry — optional for development
SENTRY_DSN=
